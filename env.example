# Kit Evo - exemplo de variaveis
# Copie para .env e altere todos os segredos antes de subir.

# -----------------------------------------------------------------------------
# Dominios publicos obrigatorios em producao
# -----------------------------------------------------------------------------
# FRONTEND_URL: dominio do painel web do EvoCRM.
# BACKEND_URL: dominio da API/gateway do EvoCRM.
# EVOGO_PUBLIC_URL: dominio da API Evolution GO/WhatsApp.
#
# Exemplo:
# FRONTEND_URL=https://crm.seudominio.com
# BACKEND_URL=https://api-crm.seudominio.com
# WS_URL=wss://api-crm.seudominio.com
# EVOGO_PUBLIC_URL=https://whatsapp.seudominio.com
#
# No Dokploy/Coolify/Easypanel, aponte cada dominio para o servico correto:
# - FRONTEND_URL -> evo-frontend, porta interna 80
# - BACKEND_URL -> evo-gateway, porta interna 3030
# - EVOGO_PUBLIC_URL -> evolution-go, porta interna 4000
#
# CORS_ORIGINS precisa conter o dominio exato aberto no navegador. Se o painel
# estiver em app-crm.seudominio.com, use app-crm.seudominio.com aqui, nao
# crm.seudominio.com.
FRONTEND_URL=https://crm.seudominio.com
BACKEND_URL=https://api-crm.seudominio.com
WS_URL=wss://api-crm.seudominio.com
EVOGO_PUBLIC_URL=https://whatsapp.seudominio.com
CORS_ORIGINS=https://crm.seudominio.com,https://api-crm.seudominio.com,https://whatsapp.seudominio.com,wss://api-crm.seudominio.com.br

# -----------------------------------------------------------------------------
# Portas expostas para uso local/VPS sem proxy
# Em paineis com proxy, normalmente o dominio aponta para a porta interna.
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
GATEWAY_PORT=3030
EVOGO_PORT=4000

# -----------------------------------------------------------------------------
# Imagens
# Use versoes fixas em producao quando possivel.
# -----------------------------------------------------------------------------
EVOCRM_TAG=latest
EVOGO_TAG=latest

# -----------------------------------------------------------------------------
# Banco e Redis
# -----------------------------------------------------------------------------
POSTGRES_DATABASE=evo_community
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=altere-este-postgres-password
REDIS_PASSWORD=altere-este-redis-password

# Bancos usados pelo Evolution GO dentro do mesmo Postgres.
EVOGO_AUTH_DATABASE=evogo_auth
EVOGO_USERS_DATABASE=evogo_users

# -----------------------------------------------------------------------------
# Segredos obrigatorios
# Gere valores fortes e unicos para cada instalacao.
# Sugestao:
# openssl rand -base64 48
# -----------------------------------------------------------------------------
SECRET_KEY_BASE=gere-um-segredo-forte
JWT_SECRET_KEY=gere-um-segredo-forte
DOORKEEPER_JWT_SECRET_KEY=gere-um-segredo-forte
EVOAI_CRM_API_TOKEN=gere-um-token-forte
ENCRYPTION_KEY=gere-um-segredo-forte
BOT_RUNTIME_SECRET=gere-um-segredo-forte
EVOGO_GLOBAL_API_KEY=gere-uma-api-key-forte

# -----------------------------------------------------------------------------
# Rails / EvoCRM
# -----------------------------------------------------------------------------
RAILS_ENV=production
RAILS_MAX_THREADS=5
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

MAILER_SENDER_EMAIL=noreply@seudominio.com
DOORKEEPER_JWT_ALGORITHM=hs256
DOORKEEPER_JWT_ISS=evo-auth-service
MFA_ISSUER=EvoCRM
SIDEKIQ_CONCURRENCY=10
ACTIVE_STORAGE_SERVICE=local

DISABLE_TELEMETRY=true
LOG_LEVEL=info
ENABLE_ACCOUNT_SIGNUP=true
ENABLE_PUSH_RELAY_SERVER=true
ENABLE_INBOX_EVENTS=true

DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m
JWT_ALGORITHM=HS256
AI_PROCESSOR_VERSION=v1

APP_URL=https://crm.seudominio.com
API_URL=https://api-crm.seudominio.com
REDIS_DB=0
REDIS_KEY_PREFIX=a2a:
REDIS_TTL=3600
HOST=0.0.0.0
PORT=8000
DEBUG=false
API_TITLE=Agent Processor Community
API_DESCRIPTION=Agent Processor Community for Evo AI
API_VERSION=1.0.0
ORGANIZATION_NAME=Evo CRM
TOOLS_CACHE_ENABLED=true
TOOLS_CACHE_TTL=3600

LISTEN_ADDR=0.0.0.0:8080
AI_CALL_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Evolution GO
# -----------------------------------------------------------------------------
EVOGO_CLIENT_NAME=evolution
EVOGO_DATABASE_SAVE_MESSAGES=false
EVOGO_WADEBUG=INFO
EVOGO_LOGTYPE=console
EVOGO_LOG_MAX_SIZE=100
EVOGO_LOG_MAX_BACKUPS=5
EVOGO_LOG_MAX_AGE=30
EVOGO_LOG_COMPRESS=true
EVOGO_CONNECT_ON_STARTUP=false
EVOGO_WEBHOOKFILES=true
EVOGO_OS_NAME=Linux

# URL que o Evolution GO chama quando recebe eventos do WhatsApp.
# Deixe vazio se ainda nao souber o endpoint receptor do EvoCRM.
# Nao coloque apenas BACKEND_URL aqui. O valor precisa ser a URL completa
# do endpoint de webhook, por exemplo:
# EVOGO_WEBHOOK_URL=https://api-crm.seudominio.com/caminho-do-webhook
EVOGO_WEBHOOK_URL=

EVOGO_AMQP_URL=
EVOGO_AMQP_GLOBAL_ENABLED=false
EVOGO_NATS_URL=
EVOGO_NATS_GLOBAL_ENABLED=false
EVOGO_MINIO_ENABLED=false
EVOGO_PROXY_HOST=
EVOGO_PROXY_PORT=
EVOGO_PROXY_USERNAME=
EVOGO_PROXY_PASSWORD=
EVOGO_EVENT_IGNORE_GROUP=false
EVOGO_EVENT_IGNORE_STATUS=true
EVOGO_QRCODE_MAX_COUNT=5
